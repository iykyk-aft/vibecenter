# Caddy reverse proxy for the Vibe Center broker.
#
# This is the IP-only, plain-HTTP config that `provision.sh` installs to
# /etc/caddy/Caddyfile. The broker listens on 127.0.0.1:7900; Caddy is the public
# entrypoint on port 80.
#
# WARNING: plain HTTP means login cookies travel unencrypted — fine for testing
# from a trusted network, but add a domain + TLS before real use.
#
# To add HTTPS later: replace the ":80" line with your domain, e.g.
#
#     broker.example.com {
#         encode gzip
#         reverse_proxy 127.0.0.1:7900 { flush_interval -1 }
#     }
#
# Caddy then auto-provisions and renews a Let's Encrypt cert. Also open 443:
#     sudo ufw allow 443/tcp

:80 {
	encode gzip

	reverse_proxy 127.0.0.1:7900 {
		# SSE: don't buffer the long-lived agent channel / streamed responses.
		flush_interval -1
	}
}
